{
  "name": "home-ai",
  "private": true,
  "version": "0.0.1",
  "description": "A personal home AI — chat UI + Anthropic SDK backend. Knowledge graph context comes in M1.",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "predev": "kill-port 3001 5173 && npm --workspace server run seed",
    "dev": "concurrently --names server,web --prefix-colors yellow,cyan --kill-others-on-fail \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace server run build && npm --workspace web run build",
    "typecheck": "npm --workspace server run typecheck && npm --workspace web run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
