{
  "name": "@home-ai/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "seed": "node --import tsx src/seed.ts",
    "migrate-sessions": "node --import tsx src/sessions/migrate.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.122",
    "@hono/node-server": "^1.13.7",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.14",
    "nanoid": "^5.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
